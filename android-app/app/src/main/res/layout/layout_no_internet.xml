<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/offline_bg"
    android:padding="32dp">

    <ImageView
        android:id="@+id/noInternetIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_no_internet"
        android:layout_marginBottom="16dp"
        android:alpha="0.8" />

    <TextView
        android:id="@+id/noInternetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="لا يوجد اتصال بالإنترنت"
        android:textSize="22sp"
        android:textColor="@color/offline_title"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/noInternetMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="يرجى التحقق من اتصال Wi-Fi أو البيانات وسيتم إعادة التحميل تلقائياً."
        android:textSize="14sp"
        android:textColor="@color/offline_message"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:maxWidth="280dp"
        android:lineSpacingExtra="4dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRetryOffline"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="إعادة المحاولة"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_primary"
        android:textStyle="bold"
        android:gravity="center"
        android:elevation="4dp"
        android:stateListAnimator="@null" />

</LinearLayout>
