<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BesooooApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
        <item name="android:windowBackground">@color/webview_bg</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="Theme.BesooooApp.Splash" parent="Theme.BesooooApp">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
    </style>

</resources>
